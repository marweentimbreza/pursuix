---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="about — pursuix"
  description="Blue team in training — I defend systems and write down how I learn to."
>
  <main>
    <section class="section">
      <div class="section-head reveal">
        <span class="cmdline"><b>~$</b> whoami &amp;&amp; cat ./focus.txt</span>
        <h3>About</h3>
      </div>
      <div class="whoami">
        <div class="term reveal">
          <div class="term-bar">
            <span class="dots"><i></i><i></i><i></i></span>
            <span>analyst — bash</span>
          </div>
          <div class="term-body">
            <p class="cmd"><b>~$</b> cat ./focus.txt</p>
            <h4>Blue team in training — I <em>defend</em> systems and write down how I learn to.</h4>
            <p>I study the defensive side of security — going deeper into how to <em>detect, prevent, and contain</em> threats. Everything here is me learning in the open, with the writing as the proof.</p>
            <p>Want to know more, or compare notes? Drop a line.</p>
            <div class="cta-row">
              <a class="btn primary" href="/contact/">$ ./say-hello →</a>
            </div>
          </div>
        </div>
        <div class="term custody reveal">
          <div class="term-bar">
            <span class="dots"><i></i><i></i><i></i></span>
            <span>chain-of-custody</span>
          </div>
          <div class="term-body">
            <dl>
              <dt>handle</dt><dd>pursuix</dd>
              <dt>mode</dt><dd>blue team in training</dd>
              <dt>focus</dt><dd>logs, traffic, detections</dd>
              <dt>certs</dt><dd><span class="prog">Security+ SY0-701 — in progress</span><br />BTL1 — planned</dd>
              <dt>code</dt><dd><a href="https://github.com/marweentimbreza">github.com/marweentimbreza</a></dd>
              <dt>x</dt><dd><a href="https://x.com/timbrezadev">x.com/timbrezadev</a></dd>
              <dt>status</dt><dd class="open">learning in the open</dd>
            </dl>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
